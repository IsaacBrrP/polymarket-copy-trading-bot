# Polymarket Copy Trading Bot - Environment Configuration

# Comma-separated list of Ethereum addresses to copy trade
# Example: USER_ADDRESSES='0xabc123...,0xdef456...'
USER_ADDRESSES=

# Your Polygon wallet address (proxy wallet)
# Example: PROXY_WALLET='0x1234567890abcdef...'
PROXY_WALLET=

# Your wallet private key (without 0x prefix)
# SECURITY WARNING: Never commit this to version control!
# Example: PRIVATE_KEY='abcdef1234567890...'
PRIVATE_KEY=

# Polygon RPC endpoint URL
# Example: RPC_URL='https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID'
RPC_URL=

# MongoDB connection string (optional, for trade history)
# Example: MONGO_URI='mongodb://localhost:27017/polymarket-bot'
MONGO_URI=

# Fetch interval in seconds (how often to check for new trades)
# Default: 1
FETCH_INTERVAL=1

# Trade multiplier (scale your position size relative to tracked traders)
# Example: 1.0 = same size, 2.0 = double size, 0.5 = half size
# Default: 1.0
TRADE_MULTIPLIER=1.0

# Maximum retry attempts for failed operations
# Default: 3
RETRY_LIMIT=3

# Enable trade aggregation (combine multiple small trades into one)
# Default: false
TRADE_AGGREGATION_ENABLED=false

# Time window for trade aggregation in seconds
# Default: 300 (5 minutes)
TRADE_AGGREGATION_WINDOW_SECONDS=300

# Monitoring server port (HTTP status/health endpoints + dashboard)
# Access dashboard at http://localhost:3001
# Access JSON status at http://localhost:3001/status
# Access health check at http://localhost:3001/health
# Default: 3001
MONITORING_PORT=3001

# Monitoring server bind address
# Use 127.0.0.1 (default) to restrict access to localhost only.
# Use 0.0.0.0 to expose on all interfaces (required inside Docker containers).
MONITORING_HOST=127.0.0.1

